# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail 읽기전용 메일함 열람 기능 (Google Cloud Console에서 발급한 전용 OAuth 클라이언트)
GMAIL_READONLY_CLIENT_ID=your-gmail-readonly-oauth-client-id
GMAIL_READONLY_CLIENT_SECRET=your-gmail-readonly-oauth-client-secret